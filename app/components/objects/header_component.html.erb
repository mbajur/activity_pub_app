<% if announce? %>
  <div class="text-gray-400 text-xs mr-1 cursor-pointer flex items-center">
    <%= tabler_icon :refresh, size: 12, class: 'mr-1' %> boosted by <%= original_author_decorated.display_username %>
  </div>
<% end %>

<div class="flex flex-row mt-0 py-3 mx-0">
  <div class="flex flex-row -space-x-5 overflow-hidden">
    <% if announce? %>
      <div class="w-auto h-auto rounded-full">
        <%= link_to profile_url do %>
          <%= image_tag original_author_decorated.avatar_url, class: 'w-9 h-9 object-cover rounded-full cursor-pointer' %>
        <% end %>
      </div>
    <% end %>

    <div class="w-auto h-auto rounded-full">
      <%= link_to profile_url do %>
        <%= image_tag avatar_url, class: 'w-9 h-9 object-cover rounded-full cursor-pointer' %>
      <% end %>
    </div>
  </div>

  <div class="flex flex-col ml-3 flex-1">
    <div class="text-gray-600 text-sm font-semibold">
      <%= link_to profile_name, profile_url %>
    </div>
    <div class="flex w-full mt-0">
      <div class="text-gray-400 text-xs mr-1 cursor-pointer">
        <%= link_to preferred_username, profile_url %>
      </div>
      <div class="text-gray-400 text-xs">
        <%= link_to object_url do %>
          • <%= time_ago_in_words(object.created_at) %> ago
        <% end %>
      </div>
      <div class="text-gray-400 text-xs ml-1">
        • <%= link_to 'url', public_object_url %>
      </div>

      <% if object.local? %>
        <div class="text-gray-400 text-xs ml-1">
          • <%= link_to 'edit', edit_panel_object_path(object) %>
        </div>
      <% end %>
    </div>
  </div>
</div>
