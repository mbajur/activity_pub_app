<turbo-frame id="<%= dom_id(object, :replies) %>" src="<%= panel_object_replies_preview_path(object) unless loaded %>">
  <% if replies.any? %>
    <% replies.each do |reply| %>
      <%= render(ReplyComponent.new(reply)) %>
    <% end %>
  <% end %>

  <%= form_with data: { controller: 'reply-form' } do %>
    <textarea placeholder="Add comment..." data-reply-form-target="content"></textarea>
  <% end %>
</turbo-frame>
